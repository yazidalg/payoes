{
  "name": "@payoes/sdk",
  "version": "0.1.2",
  "description": "Official JavaScript SDK for embedding Payoes hosted checkout on your website.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yazidalg/payoes.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://payoes.com/docs/guides/checkout-embed",
  "bugs": {
    "url": "https://github.com/yazidalg/payoes/issues"
  },
  "keywords": [
    "payoes",
    "stellar",
    "payments",
    "checkout",
    "embed",
    "sdk",
    "crypto",
    "web3"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
