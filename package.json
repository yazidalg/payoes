{
  "name": "payoes",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "tailwindcss": "^3.4.4"
  },
  "scripts": {
    "build:packages": "npm run build --workspace=@dub/utils && npm run build --workspace=@dub/ui",
    "build:sdk": "npm run build --workspace=@payoes/sdk",
    "dev": "npm run dev --workspace=web",
    "build": "npm run build:packages && npm run build:sdk && npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "npm run db:generate --workspace=web",
    "db:migrate": "npm run db:migrate --workspace=web",
    "db:setup": "npm run db:setup --workspace=web",
    "db:seed": "npm run db:seed --workspace=web",
    "db:seed:force": "npm run db:seed:force --workspace=web",
    "db:studio": "npm run db:studio --workspace=web",
    "soroban:deploy": "bash scripts/soroban-deploy-contract.sh",
    "email:dev": "npm run dev --workspace=@payoes/email",
    "docs:dev": "cd apps/docs && npx mintlify@latest dev --port 3001"
  }
}
