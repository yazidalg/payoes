{
  "name": "payoes",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "npm run db:generate --workspace=web",
    "db:migrate": "npm run db:migrate --workspace=web",
    "db:setup": "npm run db:setup --workspace=web",
    "db:studio": "npm run db:studio --workspace=web",
    "docs:dev": "cd docs && npx mintlify@latest dev --port 3001"
  }
}
