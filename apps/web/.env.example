# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# App URL (required for OAuth callbacks)
# Local:  http://localhost:3000
AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email/password demo login (optional)
AUTH_DEMO_EMAIL=demo@payoes.dev
AUTH_DEMO_PASSWORD=

# PostgreSQL
DATABASE_URL=postgresql://payoes:payoes@localhost:5432/payoes

# MinIO (S3-compatible object storage)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/payoes-uploads
S3_ACCESS_KEY=payoes
S3_SECRET_KEY=payoessecret
S3_BUCKET=payoes-uploads
S3_REGION=us-east-1

# WalletConnect (optional — enables mobile wallets in Stellar Wallet Kit)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Mintlify documentation URL (dashboard links open this in a new tab)
NEXT_PUBLIC_DOCS_URL=http://localhost:3001

# SMTP (team invitation emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Payoes <noreply@yourdomain.com>"

# Stellar sandbox payment simulation (testnet secret key with balances for paid assets)
SANDBOX_SIMULATION_SECRET_KEY=

# Stellar official asset issuers (optional — built-in defaults from Circle, Paxos, AUDC, LINK)
STELLAR_TESTNET_USDC_ISSUER=
STELLAR_MAINNET_USDC_ISSUER=
STELLAR_TESTNET_EURC_ISSUER=
STELLAR_MAINNET_EURC_ISSUER=
STELLAR_TESTNET_PYUSD_ISSUER=
STELLAR_MAINNET_PYUSD_ISSUER=
STELLAR_TESTNET_AUDD_ISSUER=
STELLAR_MAINNET_AUDD_ISSUER=
STELLAR_MAINNET_NGNC_ISSUER=
# NGNC is production-only by default; set testnet issuer to enable in sandbox
STELLAR_TESTNET_NGNC_ISSUER=

# KYC (Persona) — https://app.withpersona.com
PERSONA_API_KEY=persona_sandbox_...
PERSONA_WEBHOOK_SECRET=
PERSONA_INQUIRY_TEMPLATE_ID=itmpl_...
NEXT_PUBLIC_PERSONA_ENVIRONMENT_ID=env_...
NEXT_PUBLIC_PERSONA_INQUIRY_TEMPLATE_ID=itmpl_...

# Invoice pricing (optional — CoinGecko for volatile asset quotes)
COINGECKO_API_KEY=
INVOICE_QUOTE_TTL_MINUTES=15

# Payoes operator only — protects POST /api/cron/webhook-retries (see docs/local-setup/webhook-retry-worker.mdx)
CRON_SECRET=
