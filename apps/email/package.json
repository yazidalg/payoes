{
  "name": "@payoes/email",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "email dev --dir ./src/templates -p 3333",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^5.2.8",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.2.11",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "0.25.10",
    "typescript": "^5"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./render": {
      "import": "./src/render.ts",
      "require": "./src/render.ts"
    },
    "./templates/*": {
