{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Payoes",
  "description": "Developer-first payment infrastructure for the Stellar ecosystem.",
  "theme": "mint",
  "colors": {
    "primary": "#054fbf",
    "light": "#e8f0fc",
    "dark": "#043a99"
  },
  "logo": {
    "light": "/images/logo.svg",
    "dark": "/images/logo.svg"
  },
  "favicon": "/images/logo.svg",
  "navbar": {
    "links": []
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "footer": {
    "socials": {}
  },
  "navigation": {
    "$ref": "./config/navigation.json"
  },
  "api": {
    "openapi": "openapi/v1.yaml",
    "mdx": {
      "auth": {
        "method": "bearer"
      }
    }
  }
}
