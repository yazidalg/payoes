# Go API (apps/api) — mirrors apps/web/.env.example for shared secrets.
PORT=8080

# Public URLs
# Web UI (Next.js) origin used for redirects and CORS
WEB_URL=http://localhost:3000
# This API's public origin (OAuth callbacks, verification links)
API_URL=http://localhost:8080
AUTH_URL=http://localhost:8080

# Auth
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# PostgreSQL (external managed database)
DATABASE_URL=

# S3-compatible storage (e.g. Cloudflare R2)
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=auto

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Payoes <noreply@yourdomain.com>"

# Stellar / Soroban
STELLAR_TESTNET_OPERATOR_SECRET=
STELLAR_MAINNET_OPERATOR_SECRET=
SOROBAN_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_TESTNET_CONTRACT_ID=
SOROBAN_MAINNET_RPC_URL=
SOROBAN_MAINNET_CONTRACT_ID=

# Persona
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_INQUIRY_TEMPLATE_ID=

# Pricing
COINGECKO_API_KEY=
INVOICE_QUOTE_TTL_MINUTES=15

# Cron
CRON_SECRET=

# Integrations
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_orders,write_orders
INTEGRATIONS_STATE_SECRET=

# Optional extra CORS origins (comma-separated)
# CORS_ORIGINS=https://app.example.com
