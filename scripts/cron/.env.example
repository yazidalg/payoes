# Payoes API public URL (no trailing slash)
# Point at the Go API (apps/api), not the Next.js origin.
PAYOES_URL=http://localhost:8080

# Same value as CRON_SECRET on the Payoes API
CRON_SECRET=

# Optional: override curl binary
# CURL_BIN=/usr/bin/curl

# Optional: directory for cron log files
# LOG_DIR=/var/log/payoes-cron
