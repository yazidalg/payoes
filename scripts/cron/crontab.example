# Payoes VPS cron jobs
# Install with: crontab -e
# Replace /opt/payoes-cron with the path where you copied scripts/cron

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Escrow / QR deposit detection and settlement (every minute)
* * * * * /opt/payoes-cron/run-settlement.sh >> /opt/payoes-cron/logs/settlement.log 2>&1

# Merchant webhook retries (every 5 minutes)
*/5 * * * * /opt/payoes-cron/run-webhook-retries.sh >> /opt/payoes-cron/logs/webhook-retries.log 2>&1
