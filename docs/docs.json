{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Payoes",
  "description": "Developer-first payment infrastructure for the Stellar ecosystem.",
  "theme": "mint",
  "colors": {
    "primary": "#18181b",
    "light": "#e4e4e7",
    "dark": "#18181b"
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": "/images/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://payoes.com/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {}
  },
  "navigation": {
    "$ref": "./config/navigation.json"
  },
  "api": {
    "openapi": "openapi/v1.yaml",
    "mdx": {
      "auth": {
        "method": "bearer"
      }
    }
  }
}
