# Docker host ports
NEXTJS_PORT=3000
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Auth (openssl rand -base64 32 for AUTH_SECRET)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# PostgreSQL
DATABASE_URL=postgresql://payoes:payoes@localhost:5432/payoes

# Object storage (S3-compatible)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://pub-your-bucket.r2.dev
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=payoes
S3_REGION=auto

# Public URLs
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_DOCS_URL=https://docs.payoes.com
NEXT_PUBLIC_GITHUB_URL=https://github.com/yazidalg/payoes
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_ALLOWED_DEV_ORIGINS=

# Email (team invites)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Payoes <noreply@payoes.com>"

# Stellar operator accounts
STELLAR_TESTNET_OPERATOR_SECRET=
STELLAR_MAINNET_OPERATOR_SECRET=

# Soroban escrow contracts
SOROBAN_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_TESTNET_CONTRACT_ID=
SOROBAN_MAINNET_RPC_URL=https://mainnet.sorobanrpc.com
SOROBAN_MAINNET_CONTRACT_ID=

# Official asset issuers (USDC)
STELLAR_TESTNET_USDC_ISSUER=
STELLAR_MAINNET_USDC_ISSUER=

# KYC (Persona)
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_INQUIRY_TEMPLATE_ID=
NEXT_PUBLIC_PERSONA_ENVIRONMENT_ID=
NEXT_PUBLIC_PERSONA_INQUIRY_TEMPLATE_ID=

# Invoice pricing
COINGECKO_API_KEY=
INVOICE_QUOTE_TTL_MINUTES=5

# Background jobs (cron workers)
CRON_SECRET=

# Store integrations
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_orders,write_orders
INTEGRATIONS_STATE_SECRET=
