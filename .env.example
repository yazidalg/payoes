# Google OAuth — see docs/SETUP.md
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Turnkey MPC — see docs/SETUP.md
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=

# SQLite database file path
DATABASE_URL=./payoes.db
